---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';
import { cleanTitle } from '../lib/title';

const all = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const mainPosts = all.filter((p) => !p.data.mini);
const miniPosts = all.filter((p) => p.data.mini);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---
<Base>
  <section class="hero">
    <div class="hero-kicker">
      <span>Akshan Krithick</span>
    </div>
    <h1>Writing.</h1>
    <p class="lead">Notes and essays on machine learning, data, and the field of artificial intelligence in general. Updated whenever I feel like I have something worth saying. I try to write exclusively about things you wouldn't find information about elsewhere, most of the time. And my target audience is everyone. Regardless of where you are, you might benefit a lot from my articles, consider <a href="#subscribe">signing up for notifications</a> when I add a new post here. Thank you! </p>
    <p class="hero-aside">
      Why do I do it?<br />
      People wanting to be as good as you in something is one of the best feelings, so I do this for both of us
    </p>

    <figure class="hero-fig">
      <svg viewBox="0 0 720 210" role="img" aria-label="A training loss curve descending noisily from top left to bottom right, drawn as a chart.">
        <line class="fig-axis" x1="36" y1="16" x2="36" y2="182" />
        <line class="fig-axis" x1="36" y1="182" x2="708" y2="182" />
        <line class="fig-grid" x1="36" y1="58" x2="708" y2="58" />
        <line class="fig-grid" x1="36" y1="100" x2="708" y2="100" />
        <line class="fig-grid" x1="36" y1="141" x2="708" y2="141" />
        <text class="fig-lbl" x="44" y="28">LOSS</text>
        <text class="fig-lbl" x="708" y="200" text-anchor="end">STEPS -&gt;</text>
        <path
          class="fig-curve"
          pathLength="1"
          d="M 40 42 L 66 68 L 92 56 L 118 88 L 144 79 L 170 104 L 196 96 L 222 118 L 248 109 L 274 127 L 300 122 L 326 137 L 352 130 L 378 143 L 404 139 L 430 149 L 456 144 L 482 153 L 508 150 L 534 157 L 560 154 L 586 160 L 612 158 L 638 163 L 664 161 L 690 164"
        />
        <circle class="fig-dot" cx="690" cy="164" r="4" />
      </svg>
      <figcaption>Training loss. Still descending.</figcaption>
    </figure>
  </section>

  <section>
    <div class="post-list-header">
      <div class="section-label">Posts</div>
      <button class="mini-toggle" type="button" data-mini-toggle>
        <span data-off>+ include mini blogs</span>
        <span data-on>− hide mini blogs</span>
      </button>
    </div>
    <ul class="post-list">
      {mainPosts.map((post) => (
        <li>
          <a href={`/posts/${post.slug}/`}>
            <span class="post-title">{cleanTitle(post.data.title)}</span>
            <span class="post-date">{formatDate(post.data.date)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="mini-section">
    <div class="section-label">Mini blogs</div>
    {miniPosts.length === 0 ? (
      <p class="empty">No mini blogs yet.</p>
    ) : (
      <ul class="post-list">
        {miniPosts.map((post) => (
          <li>
            <a href={`/posts/${post.slug}/`}>
              <span class="post-title">{cleanTitle(post.data.title)}</span>
              <span class="post-date">{formatDate(post.data.date)}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <Newsletter />

  <script is:inline>
    (() => {
      const root = document.documentElement;
      document.querySelectorAll('[data-mini-toggle]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const on = root.classList.toggle('show-mini');
          localStorage.setItem('show-mini', on ? 'true' : 'false');
        });
      });
    })();
  </script>
</Base>
