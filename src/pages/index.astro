---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const mainPosts = all.filter((p) => !p.data.mini);
const miniPosts = all.filter((p) => p.data.mini);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---
<Base>
  <section class="hero">
    <h1>Writing.</h1>
    <p class="lead">Notes and essays on machine learning, data, and the field of artificial intelligence in general. Updated whenever I feel like I have something worth saying. I try to write exclusively about things you wouldn't find information about elsewhere, most of the time. And my target audience is everyone. Regardless of where you are, you might benefit a lot from my articles, consider signing up for notifications when I add a new article here. Thank you! </p>
    <p class="hero-aside">
      Why do I do it?<br />
      For you
    </p>
  </section>

  <section>
    <div class="post-list-header">
      <div class="section-label">Posts</div>
      <button class="mini-toggle" type="button" data-mini-toggle>
        <span data-off>+ include mini blogs</span>
        <span data-on>− hide mini blogs</span>
      </button>
    </div>
    <ul class="post-list">
      {mainPosts.map((post) => (
        <li>
          <a href={`/posts/${post.slug}/`}>
            <span class="post-title">{post.data.title}</span>
            <span class="post-date">{formatDate(post.data.date)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="mini-section">
    <div class="section-label">Mini blogs</div>
    {miniPosts.length === 0 ? (
      <p class="empty">No mini blogs yet.</p>
    ) : (
      <ul class="post-list">
        {miniPosts.map((post) => (
          <li>
            <a href={`/posts/${post.slug}/`}>
              <span class="post-title">{post.data.title}</span>
              <span class="post-date">{formatDate(post.data.date)}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <script is:inline>
    (() => {
      const root = document.documentElement;
      document.querySelectorAll('[data-mini-toggle]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const on = root.classList.toggle('show-mini');
          localStorage.setItem('show-mini', on ? 'true' : 'false');
        });
      });
    })();
  </script>
</Base>
