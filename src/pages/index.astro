---
import Base from '../layouts/Base.astro';
import NBShoe from '../components/NBShoe.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---
<Base>
  <section class="hero">
    <NBShoe />
    <h1>Writing.</h1>
    <p class="lead">Notes and essays on machine learning, data, and the field of artificial intelligence in general. Updated whenever I feel like I have something worth saying.</p>
    <p class="hero-aside">
      Why do I do it?<br />
      For you
    </p>
  </section>

  <section>
    <div class="section-label">Posts</div>
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/posts/${post.slug}/`}>
            <span class="post-title">{post.data.title}</span>
            <span class="post-date">{formatDate(post.data.date)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
