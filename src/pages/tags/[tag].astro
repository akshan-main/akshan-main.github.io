---
import Base from '../../layouts/Base.astro';
import { getAllTags, originalTagName } from '../../lib/tags';
import { cleanTitle } from '../../lib/title';

export async function getStaticPaths() {
  const tagsMap = await getAllTags({ includeMini: true });
  return Array.from(tagsMap.entries()).map(([slug, posts]) => ({
    params: { tag: slug },
    props: { posts, name: originalTagName(slug, posts) },
  }));
}

const { posts, name } = Astro.props;

const sorted = (posts as any[]).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const mainPosts = sorted.filter((p) => !p.data.mini);
const miniPosts = sorted.filter((p) => p.data.mini);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---
<Base title={`Tagged: ${name}`} description={`Posts tagged "${name}".`}>
  <section class="hero">
    <h1>Tagged <em>{name}</em>.</h1>
    <p class="lead">
      {mainPosts.length === 1 ? '1 post' : `${mainPosts.length} posts`} with this tag.
      <a class="muted-link" href="/tags/">All tags →</a>
    </p>
  </section>

  <section>
    <div class="post-list-header">
      <div class="section-label">Posts</div>
      <button class="mini-toggle" type="button" data-mini-toggle>
        <span data-off>+ include mini blogs</span>
        <span data-on>− hide mini blogs</span>
      </button>
    </div>
    {mainPosts.length === 0 ? (
      <p class="empty">No main posts with this tag yet — toggle "include mini blogs" to see explainers.</p>
    ) : (
      <ul class="post-list">
        {mainPosts.map((post) => (
          <li>
            <a href={`/posts/${post.slug}/`}>
              <span class="post-title">{cleanTitle(post.data.title)}</span>
              <span class="post-date">{formatDate(post.data.date)}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="mini-section">
    <div class="section-label">Mini blogs</div>
    {miniPosts.length === 0 ? (
      <p class="empty">No mini blogs with this tag yet.</p>
    ) : (
      <ul class="post-list">
        {miniPosts.map((post) => (
          <li>
            <a href={`/posts/${post.slug}/`}>
              <span class="post-title">{cleanTitle(post.data.title)}</span>
              <span class="post-date">{formatDate(post.data.date)}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <script is:inline>
    (() => {
      const root = document.documentElement;
      document.querySelectorAll('[data-mini-toggle]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const on = root.classList.toggle('show-mini');
          localStorage.setItem('show-mini', on ? 'true' : 'false');
        });
      });
    })();
  </script>
</Base>
