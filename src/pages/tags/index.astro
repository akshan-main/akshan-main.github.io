---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getAllTags, originalTagName, tagHref, tagSlug } from '../../lib/tags';

const tagsMap = await getAllTags();

const allTags = Array.from(tagsMap.entries())
  .map(([slug, posts]) => ({
    slug,
    name: originalTagName(slug, posts),
    count: posts.length,
  }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));

const bySlug = new Map(allTags.map((t) => [t.slug, t]));

const topicEntries = await getCollection('topics');
const topicSections = topicEntries
  .map((entry) => ({
    slug: entry.id,
    label: entry.data.label,
    items: entry.data.tags
      .map((raw) => bySlug.get(tagSlug(raw)))
      .filter((x): x is { slug: string; name: string; count: number } => Boolean(x)),
  }))
  .filter((t) => t.items.length > 0)
  .sort((a, b) => a.label.localeCompare(b.label));
---
<Base title="Tags" description="Browse posts by tag, grouped by topic.">
  <section class="hero">
    <h1>Tags.</h1>
    <p class="lead">Filter posts by topic or by tag. Click any tag.</p>
  </section>

  <section>
    <div class="section-label">All tags</div>
    {allTags.length === 0 ? (
      <p class="empty">No tags yet.</p>
    ) : (
      <ul class="tags">
        {allTags.map((t) => (
          <li>
            <a class="tag" href={tagHref(t.name)}>
              {t.name}
              <span class="tag-count">{t.count}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  {topicSections.map((topic) => (
    <section>
      <div class="section-label">{topic.label}</div>
      <ul class="tags">
        {topic.items.map((t) => (
          <li>
            <a class="tag" href={tagHref(t.name)}>
              {t.name}
              <span class="tag-count">{t.count}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>
