---
// New Balance 990v6 silhouette, outline only.
// Stroke is fixed light-yellow (same as light-theme bg) so it's
// invisible in light mode and reveals itself in grey mode.
---
<svg
  class="nb-shoe"
  viewBox="0 0 400 200"
  fill="none"
  stroke="#fbf6dd"
  stroke-width="2"
  stroke-linejoin="round"
  stroke-linecap="round"
  aria-hidden="true"
  focusable="false"
>
  <!-- Chunky midsole + outsole slab (the signature 990 silhouette) -->
  <path d="M 30 178
           Q 14 160, 22 138
           C 28 128, 38 122, 55 122
           L 350 122
           C 370 122, 380 132, 384 150
           L 384 170
           Q 380 180, 370 182
           L 36 182 Z" />

  <!-- Outsole / midsole separator -->
  <path d="M 26 164 L 384 164" />

  <!-- Front upper panel: toe → throat front -->
  <path d="M 55 122
           Q 42 112, 48 92
           L 90 84
           L 120 78
           C 128 82, 132 92, 135 105
           L 138 122" />

  <!-- Back upper panel: throat back → heel -->
  <path d="M 242 122
           L 248 105
           C 256 95, 268 88, 285 84
           L 320 72
           Q 355 65, 375 88
           L 375 122" />

  <!-- Tongue arcing up through the throat -->
  <path d="M 138 122 Q 190 90, 242 122" />

  <!-- Laces -->
  <path d="M 145 115 L 235 115" />
  <path d="M 150 105 L 230 105" />
  <path d="M 158 95 L 222 95" />

  <!-- Heel collar curve -->
  <path d="M 290 92 Q 335 70, 365 88" />

  <!-- Pull tab at heel back -->
  <path d="M 357 76 L 380 73 L 380 88 L 357 88 Z" />

  <!-- ENCAP detail lines in heel midsole -->
  <path d="M 335 132 L 335 160" />
  <path d="M 360 132 L 360 160" />

  <!-- Outsole tread marks -->
  <path d="M 60 178 L 60 168" />
  <path d="M 105 178 L 105 168" />
  <path d="M 150 178 L 150 168" />
  <path d="M 195 178 L 195 168" />
  <path d="M 240 178 L 240 168" />
  <path d="M 285 178 L 285 168" />
  <path d="M 330 178 L 330 168" />

  <!-- Toe-cap stitching -->
  <path d="M 45 108 C 55 96, 75 90, 110 88" />

  <!-- The N: real italic bold letterform, filled -->
  <text
    x="265"
    y="158"
    font-family="Helvetica, Arial, sans-serif"
    font-weight="900"
    font-style="italic"
    font-size="56"
    fill="#fbf6dd"
    stroke="none"
  >N</text>
</svg>
