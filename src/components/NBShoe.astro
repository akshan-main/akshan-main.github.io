---
// Decorative New Balance shoe outline.
// Stroke is a fixed light-yellow that matches the light-theme background,
// so it disappears in light mode and reveals itself when the theme is grey.
---
<svg
  class="nb-shoe"
  viewBox="0 0 300 140"
  fill="none"
  stroke="#fbf6dd"
  stroke-width="1.5"
  stroke-linejoin="round"
  stroke-linecap="round"
  aria-hidden="true"
  focusable="false"
>
  <!-- Outsole (bottom slab) -->
  <path d="M 22 112 L 278 112 L 274 124 L 26 124 Z" />
  <!-- Upper outline: toe → vamp → collar → heel -->
  <path d="M 26 112 C 18 96, 26 80, 52 74 L 92 64 C 116 54, 142 50, 172 52 L 210 58 C 244 64, 268 78, 278 96 L 278 112" />
  <!-- Tongue / lace gap -->
  <path d="M 92 64 C 104 76, 138 76, 168 52" />
  <!-- Laces -->
  <path d="M 102 70 L 148 64" />
  <path d="M 108 76 L 152 70" />
  <path d="M 114 82 L 156 76" />
  <!-- Heel collar curve -->
  <path d="M 226 60 C 238 50, 264 56, 276 76" />
  <!-- The N logo: two verticals with a diagonal between -->
  <path d="M 168 92 L 168 72 L 198 100 L 198 80" />
  <!-- Sole / upper separator -->
  <path d="M 26 110 L 278 110" />
  <!-- Tread marks -->
  <path d="M 50 124 L 50 114" />
  <path d="M 88 124 L 88 114" />
  <path d="M 128 124 L 128 114" />
  <path d="M 168 124 L 168 114" />
  <path d="M 208 124 L 208 114" />
  <path d="M 248 124 L 248 114" />
  <!-- Toe cap stitch -->
  <path d="M 32 104 C 38 94, 54 90, 76 92" />
  <!-- Eyelets (tiny dots along the lace edge) -->
  <circle cx="100" cy="68" r="1.2" />
  <circle cx="108" cy="74" r="1.2" />
  <circle cx="116" cy="80" r="1.2" />
  <circle cx="146" cy="62" r="1.2" />
  <circle cx="150" cy="68" r="1.2" />
  <circle cx="154" cy="74" r="1.2" />
</svg>
