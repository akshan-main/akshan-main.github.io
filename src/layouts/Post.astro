---
import Base from './Base.astro';
import Newsletter from '../components/Newsletter.astro';
import TagList from '../components/TagList.astro';
import { cleanTitle, titleParts } from '../lib/title';

interface Props {
  title: string;
  date: Date;
  description?: string;
  readTime?: string;
  tags?: string[];
  mini?: boolean;
}

const { title, date, description, readTime, tags = [], mini = false } = Astro.props;
const displayParts = titleParts(title);
const plainTitle = cleanTitle(title);
const dateStr = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: plainTitle,
  description: description ?? undefined,
  datePublished: date.toISOString(),
  keywords: tags.length ? tags.join(', ') : undefined,
  author: {
    '@type': 'Person',
    name: 'Akshan Krithick Ponvel',
    alternateName: 'Akshan',
    url: 'https://akshan.dev',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
};
---
<Base
  title={plainTitle}
  description={description}
  ogType="article"
  publishedTime={date}
>
  <div class="read-progress" aria-hidden="true"></div>
  <article>
    <header class="post-header">
      <div class="post-kicker">
        <span>
          <time datetime={date.toISOString()}>{dateStr}</time>
          {readTime ? ` · ${readTime}` : ''}
        </span>
        {mini && <span class="mini-badge">mini blog</span>}
      </div>
      <h1>{displayParts.map((part, i) => (i % 2 ? <em>{part}</em> : part))}</h1>
      <TagList tags={tags} />
    </header>
    <div class="post-body">
      <slot />
    </div>
    <Newsletter />
    <a class="back-link" href="/">← all posts</a>
  </article>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(articleSchema)}
  />
  <script is:inline>
    (() => {
      const bar = document.querySelector('.read-progress');
      if (!bar) return;
      const update = () => {
        const max = document.documentElement.scrollHeight - innerHeight;
        bar.style.width = (max > 0 ? (scrollY / max) * 100 : 0) + '%';
      };
      addEventListener('scroll', update, { passive: true });
      update();
    })();
  </script>
</Base>
